{
	"name": "chobble-template",
	"version": "1.0.0",
	"type": "module",
	"packageManager": "bun@1.3.6",
	"imports": {
		"#data/*": "./src/_data/*",
		"#lib/*": "./src/_lib/*",
		"#collections/*": "./src/_lib/collections/*",
		"#config/*": "./src/_lib/config/*",
		"#filters/*": "./src/_lib/filters/*",
		"#eleventy/*": "./src/_lib/eleventy/*",
		"#build/*": "./src/_lib/build/*",
		"#media/*": "./src/_lib/media/*",
		"#transforms/*": "./src/_lib/transforms/*",
		"#utils/*": "./src/_lib/utils/*",
		"#public/*": "./src/_lib/public/*",
		"#test/*": "./test/*",
		"#scripts/*": "./scripts/*",
		"#toolkit/*": "./packages/js-toolkit/*"
	},
	"scripts": {
		"build": "rm -rf _site && bun scripts/eleventy-build.js",
		"serve": "rm -rf _site && bun scripts/eleventy-build.js --serve --incremental",
		"test": "bun ./test/run-tests.js",
		"test:unit": "bun test test/unit",
		"test:integration": "bun test test/integration",
		"typecheck": "tsc --noEmit --incremental --tsBuildInfoFile tsconfig.tsbuildinfo",
		"typecheck:strict": "bun scripts/strict-typecheck-ratchet.js",
		"cpd:fp": "jscpd packages/js-toolkit/fp --min-tokens 12",
		"cpd:design-system": "jscpd src/css/design-system --min-tokens 17",
		"cpd": "jscpd && jscpd src/_lib src/_data scripts packages --min-tokens 18 --ignore '**/index.js,**/page-layouts/**,**/customise-cms/**' --ignore-pattern 'import.*from'",
		"cpd:ratchet": "bun scripts/cpd-ratchet.js",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"lint": "bunx @biomejs/biome@2.4.11 check --error-on-warnings .",
		"lint:fix": "bunx @biomejs/biome@2.4.11 check --write .",
		"lint:scss": "bunx stylelint \"src/css/**/*.scss\"",
		"lint:scss:fix": "bunx stylelint --fix \"src/css/**/*.scss\"",
		"precommit": "node test/precommit.js",
		"customise-cms": "bun scripts/customise-cms/index.js",
		"generate-pages-yml": "bun scripts/customise-cms/generate-full.js",
		"generate-cms-types": "bun scripts/generate-pages-cms-types.js",
		"generate-blocks-reference": "bun scripts/generate-blocks-reference.js",
		"screenshot": "bun scripts/screenshot.js",
		"lighthouse": "bun scripts/lighthouse.js"
	},
	"devDependencies": {
		"11ty.ts": "^0.0.7",
		"@happy-dom/global-registrator": "^20.9.0",
		"@types/bun": "^1.3.13",
		"happy-dom": "^20.9.0",
		"jscpd": "^4.0.9",
		"knip": "^5.88.1",
		"postcss-scss": "^4.0.9",
		"stylelint": "^17.10.0",
		"stylelint-config-clean-order": "^8.0.1",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-order": "^8.1.1",
		"typescript": "^5.9.3",
		"zod": "^3.25.76"
	},
	"dependencies": {
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "github:jornmineur/eleventy-img#f33b5e25c602fafeca5d374339d1e0ace74bea0b",
		"@11ty/eleventy-navigation": "^1.0.5",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@botpoison/browser": "^0.1.30",
		"@nfrasser/simple-html-tokenizer": "^0.5.11-4",
		"@quasibit/eleventy-plugin-schema": "^1.13.0",
		"@sindresorhus/slugify": "^3.0.0",
		"chrome-launcher": "^1.2.1",
		"gray-matter": "^4.0.3",
		"ical-generator": "^9.0.0",
		"instant.page": "^5.2.0",
		"json-to-pdf": "^0.1.2",
		"lighthouse": "^12.8.2",
		"linkify-html": "^4.3.2",
		"linkifyjs": "^4.3.2",
		"liquidjs": "^10.25.7",
		"markdown-it": "^14.1.1",
		"pagefind": "^1.5.2",
		"player.js": "^0.1.0",
		"playwright": "^1.59.1",
		"sass": "^1.99.0",
		"sharp": "^0.34.5",
		"uwrap": "^0.1.2",
		"yaml": "^2.8.3"
	},
	"trustedDependencies": [
		"@parcel/watcher"
	]
}
